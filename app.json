{
  "expo": {
    "name": "FixBook",
    "slug": "fixbook-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0D0E14"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.fixbook.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0D0E14"
      },
      "package": "com.fixbook.app",
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow FixBook to access your photos for post images and profile pictures."
        }
      ],
      "expo-font"
    ],
    "extra": {
      "eas": {
        "projectId": "d0f9303f-d92c-4564-baf1-759bd99d00e7"
      }
    },
    "owner": "kareem_abdelrahman"
  }
}
